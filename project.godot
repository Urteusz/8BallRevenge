; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="8 Ball Revenge"
run/main_scene="uid://b0a6ch7y3umcj"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/bg_color=Color(0.4745098, 0.52156866, 0.9843137, 1)
boot_splash/show_image=false
config/icon="uid://b8t6tcqys3kpe"

[autoload]

LoadManager="*res://scripts/load_manager.gd"
ScenePaths="*res://scripts/scene_paths.gd"
SettingsManager="*res://scripts/settings_manager.gd"
PlayerData="*res://scripts/player_data.gd"
Utils="*res://scripts/utils.gd"

[display]

window/size/viewport_width=1366
window/size/viewport_height=768
window/size/resizable=false
window/subwindows/embed_subwindows=false
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/UniParticles3D/plugin.cfg", "res://addons/terrain_3d/plugin.cfg")

[filesystem]

import/blender/enabled=false

[global_group]

table=""
balls=""
pockets=""
playerBall=""

[gui]

theme/custom_font="uid://vcecbwh0vav0"

